From ab26085d07549d2f41ec423dcc1361807ea09730 Mon Sep 17 00:00:00 2001
From: Auric <aurichardcastle@gmail.com>
Date: Fri, 17 Jul 2026 19:09:06 +0800
Subject: [PATCH 1/3] merge: reindex episodes_stats episode_index in step with
 episodes

Stats entries were extended verbatim while episodes.jsonl and the parquet
files were reindexed, so merging N single-episode datasets produced N stats
entries all with episode_index=0. The loader keys stats by episode_index,
so colliding entries silently overwrite and normalization stats come from
a subset of episodes.
---
 src/galbot_mcap2lerobot/merge_lerobot_v2_1.py | 10 +++++++++-
 1 file changed, 9 insertions(+), 1 deletion(-)

diff --git a/src/galbot_mcap2lerobot/merge_lerobot_v2_1.py b/src/galbot_mcap2lerobot/merge_lerobot_v2_1.py
index 8467638..5523db6 100644
--- a/src/galbot_mcap2lerobot/merge_lerobot_v2_1.py
+++ b/src/galbot_mcap2lerobot/merge_lerobot_v2_1.py
@@ -405,6 +405,7 @@ def merge_datasets(source_folders: list[str], output_folder: str) -> None:
         ep_stats = load_jsonl(stats_path) if os.path.exists(stats_path) else []
         tasks = load_jsonl(tasks_path) if os.path.exists(tasks_path) else []
 
+        folder_ep_map = {}
         for ep in episodes:
             old_index = ep.get("episode_index", 0)
             new_index = current_episode
@@ -415,11 +416,18 @@ def merge_datasets(source_folders: list[str], output_folder: str) -> None:
             new_ep["episode_index"] = new_index
             all_episodes.append(new_ep)
 
+            folder_ep_map[old_index] = new_index
             episode_mapping.append((folder, old_index, new_index))
             current_episode += 1
             current_frame += ep_length
 
-        all_episode_stats.extend(ep_stats)
+        # Reindex stats with the same old->new mapping as their episodes,
+        # so episodes_stats.jsonl stays one-to-one with episodes.jsonl.
+        for st in ep_stats:
+            new_st = dict(st)
+            old = new_st.get("episode_index", 0)
+            new_st["episode_index"] = folder_ep_map.get(old, old)
+            all_episode_stats.append(new_st)
 
         for task in tasks:
             if task not in all_tasks:
